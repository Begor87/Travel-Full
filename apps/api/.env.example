NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://wanderlog:wanderlog@localhost:5432/wanderlog

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Storage (S3-compatible)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=wanderlog-uploads
AWS_ENDPOINT_URL=

# Email
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@wanderlog.app

# AI
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# Exchange rates (optional — falls back to static rates if unset)
# Free key from https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=

# Weather (OpenWeatherMap) — reserved for an upcoming weather feature
OPENWEATHER_API_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
# Stricter limit on login/register attempts per IP per 15 min
AUTH_RATE_LIMIT_MAX=50
